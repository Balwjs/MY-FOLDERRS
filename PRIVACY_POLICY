<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Privacy Policy — My Folder</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    /* ─── Tokens ──────────────────────────────────────────────────── */
    :root {
      --ink:      #0d1117;
      --soft:     #4a5568;
      --muted:    #8492a6;
      --border:   rgba(0,0,0,0.08);

      --blue:     #2563eb;
      --blue-lt:  #dbeafe;
      --teal:     #0d9488;
      --teal-lt:  #ccfbf1;
      --violet:   #7c3aed;
      --violet-lt:#ede9fe;
      --amber:    #d97706;
      --amber-lt: #fef3c7;
      --rose:     #e11d48;
      --rose-lt:  #ffe4e6;
      --green:    #16a34a;
      --green-lt: #dcfce7;

      --surface:  #ffffff;
      --bg:       #f7f8fc;
      --radius:   16px;
      --shadow:   0 4px 24px rgba(0,0,0,0.07);
    }

    /* ─── Reset ───────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--ink);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── Page Grid ───────────────────────────────────────────────── */
    .page-wrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 0 24px 80px;
    }

    /* ─── Hero ────────────────────────────────────────────────────── */
    .hero {
      position: relative;
      overflow: hidden;
      border-radius: 0 0 32px 32px;
      background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 45%, #0d9488 100%);
      padding: 72px 48px 56px;
      margin-bottom: 56px;
      text-align: center;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 80% at 80% 20%, rgba(124,58,237,0.25) 0%, transparent 60%),
        radial-gradient(ellipse 50% 60% at 10% 90%, rgba(13,148,136,0.3) 0%, transparent 55%);
    }

    /* Decorative grid lines */
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    .hero-inner { position: relative; z-index: 1; }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,0.15);
      border: 1px solid rgba(255,255,255,0.25);
      backdrop-filter: blur(8px);
      color: #fff;
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 24px;
    }

    .hero-badge svg { width: 14px; height: 14px; opacity: 0.85; }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 5vw, 3.6rem);
      font-weight: 900;
      color: #fff;
      line-height: 1.1;
      margin-bottom: 16px;
      letter-spacing: -0.02em;
    }

    .hero h1 span {
      background: linear-gradient(90deg, #a5f3fc, #c4b5fd);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.75);
      max-width: 480px;
      margin: 0 auto 32px;
    }

    .hero-meta {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .hero-chip {
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.9);
      font-size: 0.8rem;
      padding: 5px 14px;
      border-radius: 100px;
      font-family: 'DM Mono', monospace;
    }

    /* ─── At-a-glance strip ───────────────────────────────────────── */
    .glance {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 48px;
    }

    .glance-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 22px 20px;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      gap: 8px;
      border-top: 4px solid transparent;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      animation: fadeUp 0.5s ease both;
    }
    .glance-card:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(0,0,0,0.1); }

    .glance-card:nth-child(1) { border-top-color: var(--blue); animation-delay: 0.05s; }
    .glance-card:nth-child(2) { border-top-color: var(--teal); animation-delay: 0.1s; }
    .glance-card:nth-child(3) { border-top-color: var(--violet); animation-delay: 0.15s; }
    .glance-card:nth-child(4) { border-top-color: var(--green); animation-delay: 0.2s; }

    .glance-icon {
      width: 40px; height: 40px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
    }
    .glance-card:nth-child(1) .glance-icon { background: var(--blue-lt); }
    .glance-card:nth-child(2) .glance-icon { background: var(--teal-lt); }
    .glance-card:nth-child(3) .glance-icon { background: var(--violet-lt); }
    .glance-card:nth-child(4) .glance-icon { background: var(--green-lt); }

    .glance-label {
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
    }
    .glance-value {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.2;
    }

    /* ─── Section wrapper ─────────────────────────────────────────── */
    .section {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      margin-bottom: 28px;
      overflow: hidden;
      animation: fadeUp 0.5s ease both;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 24px 28px 20px;
      border-bottom: 1px solid var(--border);
    }

    .section-num {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px;
      border-radius: 10px;
      font-family: 'DM Mono', monospace;
      font-size: 0.8rem;
      font-weight: 500;
      flex-shrink: 0;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .section-body {
      padding: 24px 28px;
    }

    /* section colour themes */
    .s-blue   .section-num { background: var(--blue-lt);   color: var(--blue); }
    .s-blue   .section-title { color: var(--blue); }
    .s-teal   .section-num { background: var(--teal-lt);   color: var(--teal); }
    .s-teal   .section-title { color: var(--teal); }
    .s-violet .section-num { background: var(--violet-lt); color: var(--violet); }
    .s-violet .section-title { color: var(--violet); }
    .s-amber  .section-num { background: var(--amber-lt);  color: var(--amber); }
    .s-amber  .section-title { color: var(--amber); }
    .s-rose   .section-num { background: var(--rose-lt);   color: var(--rose); }
    .s-rose   .section-title { color: var(--rose); }
    .s-green  .section-num { background: var(--green-lt);  color: var(--green); }
    .s-green  .section-title { color: var(--green); }
    .s-ink    .section-num { background: #f1f5f9;          color: var(--ink); }
    .s-ink    .section-title { color: var(--ink); }

    /* accent left border for active sections */
    .s-blue   .section-header { border-left: 4px solid var(--blue); }
    .s-teal   .section-header { border-left: 4px solid var(--teal); }
    .s-violet .section-header { border-left: 4px solid var(--violet); }
    .s-amber  .section-header { border-left: 4px solid var(--amber); }
    .s-rose   .section-header { border-left: 4px solid var(--rose); }
    .s-green  .section-header { border-left: 4px solid var(--green); }
    .s-ink    .section-header { border-left: 4px solid var(--ink); }

    /* ─── Typography ──────────────────────────────────────────────── */
    p { margin-bottom: 14px; color: var(--soft); font-size: 0.95rem; }
    p:last-child { margin-bottom: 0; }

    strong { color: var(--ink); font-weight: 600; }

    /* ─── Highlight box ───────────────────────────────────────────── */
    .highlight-box {
      display: flex;
      gap: 14px;
      background: linear-gradient(135deg, #eff6ff, #f0fdf4);
      border: 1px solid #bfdbfe;
      border-radius: 12px;
      padding: 18px 20px;
      margin-bottom: 20px;
    }
    .highlight-box .hi-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 2px; }
    .highlight-box p { margin: 0; color: #1e40af; font-size: 0.92rem; font-weight: 500; }

    /* ─── Bullet lists ────────────────────────────────────────────── */
    ul.policy-list {
      list-style: none;
      padding: 0;
      margin-bottom: 14px;
    }
    ul.policy-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 6px 0;
      font-size: 0.93rem;
      color: var(--soft);
      border-bottom: 1px solid var(--border);
    }
    ul.policy-list li:last-child { border-bottom: none; }
    ul.policy-list li::before {
      content: '✕';
      color: var(--rose);
      font-size: 0.75rem;
      font-weight: 700;
      margin-top: 4px;
      flex-shrink: 0;
      width: 16px;
      text-align: center;
    }
    ul.policy-list.check li::before {
      content: '✓';
      color: var(--teal);
    }
    ul.policy-list.dot li::before {
      content: '•';
      color: var(--blue);
      font-size: 1.1rem;
      margin-top: 1px;
    }

    /* ─── Permission cards ────────────────────────────────────────── */
    .perm-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
      margin-top: 8px;
    }

    .perm-card {
      border-radius: 12px;
      padding: 18px;
      border: 1px solid var(--border);
      position: relative;
      overflow: hidden;
    }

    .perm-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }

    .perm-card.cam  { background: #fff7ed; }
    .perm-card.cam::before  { background: var(--amber); }
    .perm-card.photo { background: #fdf4ff; }
    .perm-card.photo::before { background: var(--violet); }
    .perm-card.faceid { background: #f0fdf4; }
    .perm-card.faceid::before { background: var(--green); }
    .perm-card.mic  { background: #fff1f2; }
    .perm-card.mic::before  { background: var(--rose); }

    .perm-icon { font-size: 1.6rem; margin-bottom: 10px; }
    .perm-name {
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--ink);
      margin-bottom: 6px;
    }
    .perm-desc { font-size: 0.82rem; color: var(--soft); line-height: 1.5; margin-bottom: 10px; }

    .perm-usage {
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      color: var(--soft);
      background: rgba(0,0,0,0.04);
      border-radius: 6px;
      padding: 8px 10px;
      line-height: 1.5;
    }

    /* ─── Data table ──────────────────────────────────────────────── */
    .data-table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid var(--border); }

    table.data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.87rem;
    }

    table.data-table thead tr {
      background: linear-gradient(90deg, #1e3a8a, #2563eb);
    }
    table.data-table thead th {
      padding: 12px 16px;
      text-align: left;
      color: #fff;
      font-weight: 600;
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    table.data-table thead th:first-child { border-radius: 0; }

    table.data-table tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background 0.15s;
    }
    table.data-table tbody tr:hover { background: #f8faff; }
    table.data-table tbody tr:last-child { border-bottom: none; }

    table.data-table td {
      padding: 12px 16px;
      color: var(--soft);
      vertical-align: top;
      line-height: 1.5;
    }
    table.data-table td:first-child {
      color: var(--ink);
      font-weight: 600;
    }
    table.data-table td code {
      font-family: 'DM Mono', monospace;
      font-size: 0.78rem;
      background: #f1f5f9;
      padding: 2px 6px;
      border-radius: 4px;
      color: var(--violet);
    }

    /* ─── Security badge row ──────────────────────────────────────── */
    .security-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 14px;
      margin-top: 8px;
    }

    .sec-badge {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 14px 16px;
      background: var(--bg);
      border-radius: 10px;
      border: 1px solid var(--border);
    }
    .sec-badge-icon {
      font-size: 1.3rem;
      flex-shrink: 0;
    }
    .sec-badge-text strong {
      display: block;
      font-size: 0.82rem;
      margin-bottom: 2px;
    }
    .sec-badge-text span {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.4;
    }

    /* ─── Password row ────────────────────────────────────────────── */
    .pwd-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 8px;
    }
    @media (max-width: 540px) { .pwd-grid { grid-template-columns: 1fr; } }

    .pwd-card {
      border-radius: 12px;
      padding: 18px;
      border: 1px solid var(--border);
    }
    .pwd-card.app { background: linear-gradient(135deg, #eff6ff, #e0e7ff); border-color: #bfdbfe; }
    .pwd-card.pdf { background: linear-gradient(135deg, #f0fdf4, #dcfce7); border-color: #bbf7d0; }

    .pwd-card-title {
      font-weight: 700;
      font-size: 0.88rem;
      color: var(--ink);
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .pwd-card p { font-size: 0.82rem; margin-bottom: 0; }

    .tag {
      display: inline-block;
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      font-weight: 500;
      padding: 2px 8px;
      border-radius: 100px;
      margin-top: 6px;
    }
    .tag.blue   { background: var(--blue-lt);   color: var(--blue); }
    .tag.green  { background: var(--green-lt);  color: var(--green); }
    .tag.violet { background: var(--violet-lt); color: var(--violet); }

    /* ─── Rights grid ─────────────────────────────────────────────── */
    .rights-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: 14px;
      margin-top: 8px;
    }
    .right-card {
      text-align: center;
      padding: 20px 14px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--bg);
      transition: transform 0.2s;
    }
    .right-card:hover { transform: translateY(-2px); }
    .right-card .r-icon { font-size: 1.8rem; margin-bottom: 8px; }
    .right-card .r-title { font-weight: 700; font-size: 0.85rem; color: var(--ink); margin-bottom: 4px; }
    .right-card .r-desc  { font-size: 0.78rem; color: var(--muted); line-height: 1.4; }

    /* ─── Contact card ────────────────────────────────────────────── */
    .contact-card {
      background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 50%, #0d9488 100%);
      border-radius: 16px;
      padding: 32px;
      color: #fff;
      text-align: center;
      margin-top: 40px;
      position: relative;
      overflow: hidden;
    }
    .contact-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 80% at 80% 30%, rgba(124,58,237,0.3) 0%, transparent 60%);
    }
    .contact-card-inner { position: relative; z-index: 1; }
    .contact-card h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      margin-bottom: 10px;
    }
    .contact-card p { color: rgba(255,255,255,0.75); font-size: 0.9rem; margin-bottom: 20px; }

    .contact-items {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 12px;
    }
    .contact-item {
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      backdrop-filter: blur(6px);
      border-radius: 10px;
      padding: 12px 20px;
      text-align: left;
    }
    .contact-item .ci-label {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.55);
      margin-bottom: 3px;
    }
    .contact-item .ci-value {
      font-weight: 600;
      font-size: 0.9rem;
      color: #fff;
      font-family: 'DM Mono', monospace;
    }

    /* ─── Footer ──────────────────────────────────────────────────── */
    footer {
      text-align: center;
      padding: 32px 0 0;
      color: var(--muted);
      font-size: 0.78rem;
    }
    footer code {
      font-family: 'DM Mono', monospace;
      background: #e2e8f0;
      padding: 2px 6px;
      border-radius: 4px;
      color: var(--violet);
    }

    /* ─── TOC sidebar / sticky ────────────────────────────────────── */
    .toc-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 36px;
    }
    .toc-link {
      text-decoration: none;
      font-size: 0.78rem;
      font-weight: 500;
      padding: 5px 12px;
      border-radius: 100px;
      border: 1px solid var(--border);
      color: var(--soft);
      background: var(--surface);
      transition: all 0.15s;
    }
    .toc-link:hover {
      background: var(--blue);
      color: #fff;
      border-color: var(--blue);
    }

    /* ─── Animations ──────────────────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .section { animation-delay: calc(var(--i, 0) * 0.06s); }

    /* ─── Responsive ──────────────────────────────────────────────── */
    @media (max-width: 600px) {
      .hero { padding: 48px 24px 40px; }
      .section-header { padding: 18px 20px 16px; }
      .section-body  { padding: 18px 20px; }
    }

    /* ─── Inline note ─────────────────────────────────────────────── */
    .note {
      background: #fefce8;
      border-left: 3px solid var(--amber);
      padding: 10px 14px;
      border-radius: 0 8px 8px 0;
      font-size: 0.83rem;
      color: #78350f;
      margin-top: 12px;
    }

    /* sub-section headings inside body */
    .sub-heading {
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--ink);
      margin: 18px 0 8px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .sub-heading .dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }
  </style>
</head>

<body>
  <!-- HERO ─────────────────────────────────────────────────────────── -->
  <div class="hero">
    <div class="hero-inner">
      <div class="hero-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Privacy Policy
      </div>

      <h1>My <span>Folder</span></h1>
      <p class="hero-sub">A personal file manager that keeps your data exactly where it belongs — on your device, under your control.</p>

      <div class="hero-meta">
        <span class="hero-chip">Effective: April 20, 2026</span>
        <span class="hero-chip">com.BJ.MyFolder</span>
        <span class="hero-chip">iOS 17+</span>
        <span class="hero-chip">Developer: Balwinder Singh</span>
      </div>
    </div>
  </div>

  <div class="page-wrap">

    <!-- AT-A-GLANCE ─────────────────────────────────────────────── -->
    <div class="glance">
      <div class="glance-card">
        <div class="glance-icon">📵</div>
        <div class="glance-label">Data Collected</div>
        <div class="glance-value">None</div>
      </div>
      <div class="glance-card">
        <div class="glance-icon">🌐</div>
        <div class="glance-label">Network Connections</div>
        <div class="glance-value">Zero</div>
      </div>
      <div class="glance-card">
        <div class="glance-icon">📦</div>
        <div class="glance-label">Data Sharing</div>
        <div class="glance-value">Never</div>
      </div>
      <div class="glance-card">
        <div class="glance-icon">📱</div>
        <div class="glance-label">Storage</div>
        <div class="glance-value">100% On-Device</div>
      </div>
    </div>

    <!-- TABLE OF CONTENTS ──────────────────────────────────────── -->
    <div class="toc-strip">
      <a class="toc-link" href="#s1">1. What We Collect</a>
